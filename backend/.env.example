# ─── Portfolio Backend Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file to version control.

# MongoDB connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/?appName=Cluster0

# Server config
PORT=5000
NODE_ENV=development

# Frontend origin (set to your deployed Netlify URL in production)
CLIENT_URL=http://localhost:5173

# Rate limiting (requests per window)
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Email (SMTP via Gmail App Password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-16-char-app-password
EMAIL_FROM=your@gmail.com
EMAIL_TO=your@gmail.com

# Admin API secret (use a random UUID or long string)
# Generate one: https://www.uuidgenerator.net/
ADMIN_SECRET=replace-with-a-random-secret-string
